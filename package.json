{
  "name": "edugenius",
  "version": "1.0.0",
  "description": "EduGenius - Autonomous AI Agent Platform for Education",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "education",
    "ai",
    "tutoring",
    "agents",
    "autonomous",
    "edtech"
  ],
  "author": "EduGenius Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.12.0",
    "@types/pg": "^8.18.0",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.33",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
