      "question": "The number of bijective functions from {1,2,3} to {a,b,c} is",
      "options": {
        "A": "6",
        "B": "9",
        "C": "27",
        "D": "3"
      },
      "correct_answer": "A",
      "explanation": "The number of bijective (one-to-one, onto) functions between two n-element sets is n! = 3! = 6.",
      "difficulty": "easy",
      "marks": 2,
      "negative_marks": -0.67,
      "tags": ["functions", "bijective", "counting"]
